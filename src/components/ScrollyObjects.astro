---
// Apple-style Scrolly Object Controller (Pure High-End CSS 3D Edition)
import ScrollyAiCore from './ScrollyAiCore.astro';
import ScrollyServerRack from './ScrollyServerRack.astro';
import ScrollyGlobe from './ScrollyGlobe.astro';
import ScrollyPhone from './ScrollyPhone.astro';
import ScrollyLocation from './ScrollyLocation.astro';
import ScrollyPhoneIcon from './ScrollyPhoneIcon.astro';
import ScrollyEnterpriseCore from './ScrollyEnterpriseCore.astro';
import ScrollyAnalytics from './ScrollyAnalytics.astro';
import ScrollyNetwork from './ScrollyNetwork.astro';
---
<div id="apple-scrolly-canvas">
   
   <!-- 1. AI Core -->
   <div id="obj-ai" class="scrolly-item" style="opacity: 0; visibility: hidden;">
      <ScrollyAiCore />
   </div>

   <!-- 2. Server / Big Data -->
   <div id="obj-data" class="scrolly-item" style="opacity: 0; visibility: hidden;">
      <ScrollyServerRack />
   </div>

   <!-- 3. Globe / Network -->
   <div id="obj-globe" class="scrolly-item" style="opacity: 0; visibility: hidden;">
      <ScrollyGlobe />
   </div>

   <!-- 4. Mobile Phone App -->
   <div id="obj-phone" class="scrolly-item" style="opacity: 0; visibility: hidden;">
      <ScrollyPhone />
   </div>

   <!-- 5. Location / Radar -->
   <div id="obj-location" class="scrolly-item" style="opacity: 0; visibility: hidden;">
      <ScrollyLocation />
   </div>

   <!-- 6. Communication Hub -->
   <div id="obj-comms" class="scrolly-item" style="opacity: 0; visibility: hidden;">
      <ScrollyPhoneIcon />
   </div>

   <!-- NEW: Enterprise/ERP Core -->
   <div id="obj-enterprise" class="scrolly-item" style="opacity: 0; visibility: hidden;">
      <ScrollyEnterpriseCore />
   </div>

   <!-- NEW: Analytics/Insights -->
   <div id="obj-analytics" class="scrolly-item" style="opacity: 0; visibility: hidden;">
      <ScrollyAnalytics />
   </div>

   <!-- NEW: Network Node Mesh (API) -->
   <div id="obj-network" class="scrolly-item" style="opacity: 0; visibility: hidden;">
      <ScrollyNetwork />
   </div>
</div>

<style>
#apple-scrolly-canvas {
   position: fixed;
   top: 0; left: 0; width: 100%; height: 100vh;
   pointer-events: none;
   z-index: 1; /* Behind text content (z-index:10) — objects are background decoration */
   /* Safari fix: Do NOT use transform-style: preserve-3d on fixed container. */
}

.scrolly-item {
   position: absolute;
   top: 50%; left: 50%;
   transform-origin: center center;
   pointer-events: none;
   will-change: transform, opacity;
   /* Safari: use visibility alongside opacity to guarantee hidden */
   visibility: hidden;
   opacity: 0;
   /* GPU compositing for Safari */
   -webkit-backface-visibility: hidden;
   backface-visibility: hidden;
   -webkit-transform: translateZ(0);
}

/* Active object: make visible but behind text */
.scrolly-item.is-active {
   visibility: visible;
   opacity: 0.45; /* Subtle background presence — never blocks text */
}

/* Only active object gets pointer events */
.scrolly-item.is-active > :global(*) {
   pointer-events: auto !important;
}
</style>

<script>
function initScrollyObjects() {
   const objs = {
      'ai': document.getElementById('obj-ai'),
      'data': document.getElementById('obj-data'),
      'globe': document.getElementById('obj-globe'),
      'phone': document.getElementById('obj-phone'),
      'location': document.getElementById('obj-location'),
      'comms': document.getElementById('obj-comms'),
      'enterprise': document.getElementById('obj-enterprise'),
      'analytics': document.getElementById('obj-analytics'),
      'network': document.getElementById('obj-network')
   };

   let currentObjId = null;
   let targetX = 0, targetY = 0, targetScale = 1;
   let targetRotX = 0, targetRotY = 0, targetRotZ = 0;
   let targetOpacity = 0;

   // MOBILE STATIC OVERRIDE
   if (window.innerWidth <= 768) {
       const canvas = document.getElementById('apple-scrolly-canvas');
       if (canvas) {
           canvas.style.position = 'static';
           canvas.style.height = '0';
           canvas.style.overflow = 'visible';
       }

       document.querySelectorAll('.scrolly-container').forEach(c => {
           (c as HTMLElement).style.height = 'auto';
       });

       const cards = document.querySelectorAll('.scrolly-card-wrapper');
       cards.forEach(card => {
           (card as HTMLElement).style.height = 'auto';
           (card as HTMLElement).style.minHeight = '100vh';

           const objId = card.getAttribute('data-obj');
           if (objId && objs[objId]) {
               const elem = objs[objId]!;
               elem.style.position = 'relative';
               elem.style.top = '0';
               elem.style.left = '0';
               elem.style.transform = 'scale(0.8)';
               elem.style.opacity = '1';
               elem.style.pointerEvents = 'auto';
               elem.classList.remove('scrolly-item');
               elem.style.display = 'flex';
               elem.style.justifyContent = 'center';
               elem.style.marginBottom = '2rem';
               elem.style.zIndex = '5';
               card.prepend(elem);
           }
       });
       return;
   }

   // ─── SYNCHRONIZED ANIMATION STATE ───
   // Current interpolated values (what's actually rendered)
   let cx = 0, cy = 0, cs = 1, crx = 0, cry = 0, crz = 0, cOpacity = 0;
   // Scroll-derived data (written by scroll handler, read by rAF loop)
   let scrollDirty = false;
   let pendingObjId: string | null = null;
   let pendingProgress = 0;
   let pendingActiveCard: Element | null = null;

   // Delta-time-aware lerp for frame-rate independence
   const BASE_LERP = 0.12; // Much tighter than old 0.06
   let lastFrameTime = performance.now();

   function lerp(start: number, end: number, amt: number): number {
      return (1 - amt) * start + amt * end;
   }

   // ─── SINGLE UNIFIED rAF LOOP ───
   function render(now: number) {
      // Delta-time correction: normalize to 16.67ms (60fps baseline)
      const dt = Math.min(now - lastFrameTime, 50); // cap to avoid jumps after tab switch
      lastFrameTime = now;
      const dtFactor = dt / 16.667;
      const lerpAmt = 1 - Math.pow(1 - BASE_LERP, dtFactor);

      // Interpolate all values towards targets
      cx = lerp(cx, targetX, lerpAmt);
      cy = lerp(cy, targetY, lerpAmt);
      cs = lerp(cs, targetScale, lerpAmt);
      crx = lerp(crx, targetRotX, lerpAmt);
      cry = lerp(cry, targetRotY, lerpAmt);
      crz = lerp(crz, targetRotZ, lerpAmt);
      cOpacity = lerp(cOpacity, targetOpacity, lerpAmt * 1.5); // opacity transitions faster

      if (currentObjId && objs[currentObjId]) {
         // Cap opacity at 0.45 so objects stay behind text as subtle decoration
         const maxOpacity = 0.45;
         const clampedOpacity = Math.max(0, Math.min(maxOpacity, cOpacity));
         // Safari fix: use visibility to truly hide objects (opacity:0 leaks through preserve-3d)
         objs[currentObjId]!.style.opacity = String(clampedOpacity);
         objs[currentObjId]!.style.visibility = clampedOpacity > 0.01 ? 'visible' : 'hidden';
         objs[currentObjId]!.style.transform = `translate(calc(-50% + ${cx}vw), calc(-50% + ${cy}vh)) scale(${cs}) rotateX(${crx}deg) rotateY(${cry}deg) rotateZ(${crz}deg)`;
      }

      requestAnimationFrame(render);
   }
   requestAnimationFrame(render);

   // ─── SCROLL DATA COLLECTOR (runs on scroll, no DOM writes except data caching) ───
   const cards = document.querySelectorAll('.scrolly-card-wrapper');

   function processScroll() {
      const wh = window.innerHeight;
      
      let activeCard: Element | null = null;
      let minDistance = Infinity;
      
      for (let i = 0; i < cards.length; i++) {
         const objAttr = cards[i].getAttribute('data-obj');
         if (!objAttr) continue;
         
         const rect = cards[i].getBoundingClientRect();
         const cardCenter = rect.top + (rect.height / 2);
         const screenCenter = wh / 2;
         const dist = Math.abs(cardCenter - screenCenter);
         
         if (dist < minDistance && dist < wh * 0.6) {
             minDistance = dist;
             activeCard = cards[i];
         }
      }

      if (activeCard) {
         const rect = activeCard.getBoundingClientRect();
         const centerOffset = rect.top + (rect.height / 2) - (wh / 2);
         const progress = -(centerOffset / wh); 
         const objId = activeCard.getAttribute('data-obj');

         if (objId && objs[objId]) {
            // Handle object switching with smooth crossfade
            if (currentObjId !== objId) {
               if (currentObjId && objs[currentObjId]) {
                  // Immediately hide old object — Safari needs visibility:hidden, not just opacity:0
                  objs[currentObjId]!.style.opacity = '0';
                  objs[currentObjId]!.style.visibility = 'hidden';
                  objs[currentObjId]!.classList.remove('is-active');
               }
               currentObjId = objId;
               cOpacity = 0; // Reset interpolated opacity for smooth fade-in
            }
            
            targetOpacity = 0.45; // Objects max at 0.45 opacity (behind text)
            objs[currentObjId]!.classList.add('is-active');

            const clampedProgress = Math.max(-2, Math.min(2, progress));

            const isMobile = window.innerWidth <= 768;
            
            let tx = parseFloat(activeCard.getAttribute('data-tx') || '0');
            let ty = parseFloat(activeCard.getAttribute('data-ty') || '0');
            let scale = parseFloat(activeCard.getAttribute('data-scale') || '1');
            
            if (isMobile) {
                tx = 0;
                ty = -35; 
                scale = scale * 0.55;
            }

            const baseRx = parseFloat(activeCard.getAttribute('data-rx') || '0');
            const baseRy = parseFloat(activeCard.getAttribute('data-ry') || '0');
            const baseRz = parseFloat(activeCard.getAttribute('data-rz') || '0');

            const scrubRot = parseFloat(activeCard.getAttribute('data-scrub-rot') || '25');
            const scrubY = parseFloat(activeCard.getAttribute('data-scrub-y') || '0');

            targetX = tx;
            targetY = ty + (clampedProgress * scrubY); 
            targetScale = scale;
            
            let safeRx = baseRx * 0.2;
            let safeRy = baseRy * 0.2;
            let safeScrub = scrubRot * 0.15;
            
            targetRotX = safeRx + (clampedProgress * safeScrub); 
            targetRotY = safeRy + (clampedProgress * safeScrub * 1.5); 
            targetRotZ = baseRz * 0.2;

            // ── Per-object interactive scroll physics ──

            if (objId === 'ai') {
                const orb = document.getElementById('ai-scroll-orb');
                const rings = document.getElementById('ai-scroll-rings');
                const core = document.getElementById('ai-scroll-core');
                
                if (orb && rings && core) {
                    const coreZ = 25 + Math.max(0, clampedProgress * 60); 
                    core.style.transform = `translate(-50%, -50%) translateZ(${coreZ}px) rotateZ(${clampedProgress * 15}deg)`;
                    rings.style.transform = `scale(${1 + Math.abs(clampedProgress) * 0.3}) translateZ(${clampedProgress * 40}px)`;
                    orb.style.transform = `translate(-50%, -50%) scale(${1 + Math.abs(clampedProgress) * 0.2})`;
                }
            }

            if (objId === 'data') {
                const b1 = document.getElementById('server-blade-1');
                const b2 = document.getElementById('server-blade-2');
                const b3 = document.getElementById('server-blade-3');
                
                if (b1 && b2 && b3) {
                    const pullOutMaster = Math.max(0, clampedProgress * 50); 
                    const pullOutStorage = Math.max(0, (clampedProgress - 0.5) * 60); 
                    const pullOutCompute = Math.max(0, (clampedProgress - 1) * 70); 

                    b1.style.transform = `translateZ(${pullOutMaster}px)`;
                    b2.style.transform = `translateZ(${pullOutStorage}px)`;
                    b3.style.transform = `translateZ(${pullOutCompute}px)`;
                }
            }

            if (objId === 'globe') {
                const rings = document.getElementById('globe-rings');
                const nodes = document.getElementById('globe-nodes');
                
                if (rings && nodes) {
                    const gyroRot = clampedProgress * 40; 
                    rings.style.transform = `rotateX(${gyroRot}deg) rotateY(${-gyroRot * 0.5}deg) scale(${1 + Math.abs(clampedProgress) * 0.05})`;
                    nodes.style.transform = `rotateY(${gyroRot * 2}deg) translateZ(${clampedProgress * 20}px)`;
                }
            }

            if (objId === 'location') {
               const pin = document.querySelector('.mega-location-3d .pin-group') as HTMLElement;
               const scanLine = document.querySelector('.mega-location-3d .scan-line') as HTMLElement;
               if (pin && scanLine) {
                  pin.style.transform = `translateY(${clampedProgress * 20}px) rotateY(${clampedProgress * 30}deg)`;
                  const speed = 4 / (1 + Math.abs(clampedProgress));
                  scanLine.style.animationDuration = `${speed}s`;
               }
            }

            if (objId === 'comms') {
               const core = document.querySelector('.mega-comms-3d .comms-core') as HTMLElement;
               const rings = document.querySelector('.mega-comms-3d .data-rings') as HTMLElement;
               if (core && rings) {
                  core.style.transform = `scale(${1 + Math.abs(clampedProgress) * 0.2}) rotateZ(${clampedProgress * 20}deg)`;
                  rings.style.transform = `rotateX(${75 + clampedProgress * 10}deg) rotateZ(${clampedProgress * 45}deg)`;
               }
            }

            if (objId === 'enterprise') {
                const vault = document.getElementById('enterprise-main-vault');
                const core = document.getElementById('enterprise-inner-core');
                
                if (vault && core) {
                    vault.style.transform = `scale(${1 + Math.max(0, clampedProgress * 0.2)}) rotateY(${clampedProgress * 30}deg) rotateX(${clampedProgress * 15}deg)`;
                    core.style.transform = `scale(${1 + Math.abs(clampedProgress) * 0.5})`;
                }
            }

            if (objId === 'analytics') {
                const station = document.querySelector('.scrolly-station-3d') as HTMLElement;
                const bars = document.querySelectorAll('.scrolly-station-3d .bar-fill');
                if (station && bars.length > 0) {
                    station.style.transform = `scale(${1 + Math.abs(clampedProgress) * 0.2}) rotateY(${clampedProgress * 40}deg) rotateX(${clampedProgress * 15}deg)`;
                    bars.forEach((bar, i) => {
                        (bar as HTMLElement).style.height = `${40 + (i * 10) + (Math.abs(clampedProgress) * 30)}%`;
                    });
                }
            }

            if (objId === 'network') {
                const sat = document.getElementById('network-satellite');
                const wings = document.querySelectorAll('.solar-wing');
                if (sat) {
                    sat.style.transform = `scale(${1 + Math.abs(clampedProgress) * 0.2}) rotateY(${clampedProgress * 60}deg) rotateX(${clampedProgress * 25}deg) translateZ(${Math.abs(clampedProgress) * 50}px)`;
                }
                if (wings.length === 2) {
                    (wings[0] as HTMLElement).style.transform = `translateY(-50%) rotateY(${15 + clampedProgress * 45}deg)`;
                    (wings[1] as HTMLElement).style.transform = `translateY(-50%) rotateY(${-15 - clampedProgress * 45}deg)`;
                }
            }

            if (objId === 'phone') {
                const screen = document.getElementById('phone-screen-inner');
                const scrollView = document.getElementById('phone-scroll-view');
                const theme = activeCard.getAttribute('data-phone-color');
                
                if (theme && screen) {
                   screen.style.background = theme;
                }
                
                if (scrollView) {
                   const innerScrollY = Math.max(0, (clampedProgress + 1.5) * 80); 
                   scrollView.style.transform = `translateY(-${innerScrollY}px)`;
                }
            }
         } else {
             // No valid object for this card
             if (currentObjId && objs[currentObjId]) {
                 targetOpacity = 0;
                 if (cOpacity < 0.01) {
                    objs[currentObjId]!.style.visibility = 'hidden';
                    objs[currentObjId]!.classList.remove('is-active');
                    currentObjId = null;
                 }
             }
         }
      } else {
         // No active card at all
         if (currentObjId && objs[currentObjId]) {
             targetOpacity = 0;
             if (cOpacity < 0.01) {
                objs[currentObjId]!.style.visibility = 'hidden';
                objs[currentObjId]!.classList.remove('is-active');
                currentObjId = null;
             }
         }
      }
   }

   // Throttle scroll to rAF for perfect sync with render loop
   let scrollTicking = false;
   window.addEventListener('scroll', () => {
      if (!scrollTicking) {
         scrollTicking = true;
         requestAnimationFrame(() => {
            processScroll();
            scrollTicking = false;
         });
      }
   }, { passive: true });

   // Initial calculation
   processScroll();
}
document.addEventListener('DOMContentLoaded', initScrollyObjects);
</script>
